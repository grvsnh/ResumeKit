\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{components/education}[2026/07/12 ResumeKit Education]

\RequirePackage{etoolbox}
\RequirePackage{tabularx}

\def\RK@EducationDegree{}
\def\RK@EducationInstitute{}
\def\RK@EducationDuration{}
\def\RK@EducationLocation{}
\def\RK@EducationGrade{}

\newenvironment{ResumeEducation}
{
    \RKClear{\RK@EducationDegree}
    \RKClear{\RK@EducationInstitute}
    \RKClear{\RK@EducationDuration}
    \RKClear{\RK@EducationLocation}
    \RKClear{\RK@EducationGrade}
}
{
    \begin{tabular*}{\textwidth}{@{}l@{\extracolsep{\fill}}r@{}}
        \RKTitle{\RK@EducationDegree} &
        \RK@EducationDuration
    \end{tabular*}

    \RKSmallSpace

    \RKSubtitle{\RK@EducationInstitute}

    \RKIfEmpty{\RK@EducationLocation}
    {}
    {
        \RKSeparator
        \RK@EducationLocation
    }

    \RKIfEmpty{\RK@EducationGrade}
    {}
    {
        \RKSmallSpace

        \textbf{Grade:} \RK@EducationGrade
    }

    \RKSpace
}

\newcommand{\ResumeEducationDegree}[1]{%
    \gdef\RK@EducationDegree{#1}%
}

\newcommand{\ResumeEducationInstitute}[1]{%
    \gdef\RK@EducationInstitute{#1}%
}

\newcommand{\ResumeEducationDuration}[1]{%
    \gdef\RK@EducationDuration{#1}%
}

\newcommand{\ResumeEducationLocation}[1]{%
    \gdef\RK@EducationLocation{#1}%
}

\newcommand{\ResumeEducationGrade}[1]{%
    \gdef\RK@EducationGrade{#1}%
}

% User-facing Education environment
\newenvironment{Education}{%
    \begin{ResumeEducation}%
    \let\Degree\ResumeEducationDegree
    \let\Institute\ResumeEducationInstitute
    \let\EducationDuration\ResumeEducationDuration
    \let\EducationLocation\ResumeEducationLocation
    \let\Grade\ResumeEducationGrade
}{%
    \end{ResumeEducation}%
}

\endinput