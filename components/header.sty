\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{components/header}[2026/07/12 ResumeKit Header]

\newcommand{\ResumeHeader}{%
    \begin{center}
        {\ResumeHeaderNameStyle\RK@ProfileName}\par
        \vspace{4pt}
        {\ResumeHeaderContactStyle%
            \def\RK@HeaderSep{}%
            \ifcsempty{RK@ProfileLocation}{}{%
                \RK@ProfileLocation
                \def\RK@HeaderSep{\RKSeparator}%
            }%
            \ifcsempty{RK@ProfileEmail}{}{%
                \RK@HeaderSep\href{mailto:\RK@ProfileEmail}{\RK@ProfileEmail}%
                \def\RK@HeaderSep{\RKSeparator}%
            }%
            \ifcsempty{RK@ProfilePhone}{}{%
                \RK@HeaderSep\href{tel:\RK@ProfilePhone}{\RK@ProfilePhone}%
                \def\RK@HeaderSep{\RKSeparator}%
            }%
            \ifcsempty{RK@ProfileLinks}{}{%
                \RK@HeaderSep\RK@ProfileLinks
            }%
        }%
    \end{center}%
    \vspace{-6pt}%
}

\endinput