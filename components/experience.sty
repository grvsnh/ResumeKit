\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{components/experience}[2026/07/12 ResumeKit Experience]

\RequirePackage{etoolbox}
\RequirePackage{tabularx}

\def\RK@ExperienceRole{}
\def\RK@ExperienceCompany{}
\def\RK@ExperienceDuration{}
\def\RK@ExperienceLocation{}
\def\RK@ExperienceBullets{}

\newenvironment{ResumeExperience}
{
    \RKClear{\RK@ExperienceRole}
    \RKClear{\RK@ExperienceCompany}
    \RKClear{\RK@ExperienceDuration}
    \RKClear{\RK@ExperienceLocation}
    \RKClear{\RK@ExperienceBullets}
}
{
    \begin{tabular*}{\textwidth}{@{}l@{\extracolsep{\fill}}r@{}}
        \RKTitle{\RK@ExperienceRole} &
        \RK@ExperienceDuration
    \end{tabular*}

    \RKSmallSpace

    \RKSubtitle{\RK@ExperienceCompany}

    \RKIfEmpty{\RK@ExperienceLocation}
    {}
    {
        \RKSeparator
        \RK@ExperienceLocation
    }

    \RKSmallSpace

    \RKRenderList{\RK@ExperienceBullets}

    \RKSpace
}

\newcommand{\ResumeExperienceRole}[1]{%
    \gdef\RK@ExperienceRole{#1}%
}

\newcommand{\ResumeExperienceCompany}[1]{%
    \gdef\RK@ExperienceCompany{#1}%
}

\newcommand{\ResumeExperienceDuration}[1]{%
    \gdef\RK@ExperienceDuration{#1}%
}

\newcommand{\ResumeExperienceLocation}[1]{%
    \gdef\RK@ExperienceLocation{#1}%
}

\newcommand{\ResumeExperienceBullet}[1]{%
    \gappto\RK@ExperienceBullets{%
        \item #1
    }
}

% User-facing Experience environment
\newenvironment{Experience}{%
    \begin{ResumeExperience}%
    \let\Role\ResumeExperienceRole
    \let\Company\ResumeExperienceCompany
    \let\Duration\ResumeExperienceDuration
    \let\WorkLocation\ResumeExperienceLocation
    \let\ExperienceBullet\ResumeExperienceBullet
}{%
    \end{ResumeExperience}%
}

\endinput