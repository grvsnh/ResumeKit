\def\RK@Theme{}
\def\RK@Font{}
\def\RK@Density{}
\def\RK@Accent{}

\def\RK@ProfileName{}
\def\RK@ProfileLocation{}
\def\RK@ProfileEmail{}
\def\RK@ProfilePhone{}
\def\RK@ProfileLinks{}

\newcommand{\ResumeSetTheme}[1]{%
    \gdef\RK@Theme{#1}%
}

\newcommand{\ResumeSetFont}[1]{%
    \gdef\RK@Font{#1}%
}

\newcommand{\ResumeSetDensity}[1]{%
    \gdef\RK@Density{#1}%
}

\newcommand{\ResumeSetAccent}[1]{%
    \gdef\RK@Accent{#1}%
}

\newcommand{\ProfileName}[1]{%
    \gdef\RK@ProfileName{#1}%
}

\newcommand{\ProfileLocation}[1]{%
    \gdef\RK@ProfileLocation{#1}%
}

\newcommand{\ProfileEmail}[1]{%
    \gdef\RK@ProfileEmail{#1}%
}

\newcommand{\ProfilePhone}[1]{%
    \gdef\RK@ProfilePhone{#1}%
}

% Profile command aliases
\newcommand{\Name}[1]{\ProfileName{#1}}
\newcommand{\Location}[1]{\ProfileLocation{#1}}
\newcommand{\Email}[1]{\ProfileEmail{#1}}
\newcommand{\Phone}[1]{\ProfilePhone{#1}}

% Profile social link helpers
\newcommand{\ProfileGithub}[2]{\ProfileLink{GitHub}{#1}{#2}}
\newcommand{\ProfileLinkedIn}[2]{\ProfileLink{LinkedIn}{#1}{#2}}
\newcommand{\ProfileWebsite}[2]{\ProfileLink{Website}{#1}{#2}}

\newcommand{\ProfileLink}[3]{%
    \ifcsempty{RK@ProfileLinks}
    {
        \gdef\RK@ProfileLinks{\href{#2}{#3}}
    }
    {
        \gappto\RK@ProfileLinks{%
            \RKSeparator\href{#2}{#3}%
        }
    }
}

